{
  "version": 1,
  "author": "Bachelor 3IASD - TP Arduino",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp", "top": 72, "left": 10, "attrs": {} },
    { "type": "wokwi-dht22", "id": "dht1", "top": 56, "left": 320, "attrs": { "temperature": "25", "humidity": "50" } },
    { "type": "wokwi-resistor", "id": "r1", "top": 168, "left": 306, "attrs": { "value": "10000" } }
  ],
  "connections": [
    [ "esp:3V3", "dht1:VCC", "red", [] ],
    [ "esp:GND.1", "dht1:GND", "black", [] ],
    [ "esp:15", "dht1:SDA", "green", [] ],
    [ "dht1:SDA", "r1:1", "green", [] ],
    [ "r1:2", "esp:3V3", "red", [] ]
  ],
  "serialMonitor": { "display": "terminal", "newline": "lf" }
}
